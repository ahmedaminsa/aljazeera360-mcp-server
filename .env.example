# Al Jazeera 360 MCP Server — Environment Variables
# Copy this file to .env and fill in values as needed.

# Recommended: Refresh token for automatic token renewal (~1 year validity).
# Get this from browser localStorage key "dice:refreshToken" after logging in.
# This is the most reliable auth method — the server auto-refreshes every 10 min.
# AJ360_REFRESH_TOKEN=eyJ...

# Optional: Firebase auth token for immediate access (expires in ~10 minutes).
# The server works without this (guest mode with auto-refresh).
# AJ360_AUTH_TOKEN=eyJ...

# Optional: Override the default platform API key.
# The default key is public (visible in browser network requests).
# AJ360_API_KEY=your-api-key-here  # Get from browser DevTools → Network → any request to dce-frontoffice.imggaming.com

# Transport mode: "stdio" for local MCP clients, "sse" for cloud/HTTP deployment.
# MCP_TRANSPORT=stdio

# Port for HTTP/SSE transport (only used when MCP_TRANSPORT=sse).
# MCP_PORT=8080

# --- Tool Profiles ---
# By default only the 8 core discovery tools are registered (best for end users —
# a small toolset keeps AI tool selection accurate). Set to 1 to also register
# the 16 SEO & analytics tools (for content teams and SEO analysts).
# AJ360_ENABLE_SEO_TOOLS=1

# --- Analytics & Dashboard ---
# Enable/disable the analytics dashboard (default: true)
# AJ360_ENABLE_DASHBOARD=true

# Dashboard port (default: 9090) — access at http://localhost:9090
# AJ360_DASHBOARD_PORT=9090

# Analytics database path (default: analytics.db in current directory)
# AJ360_ANALYTICS_DB=analytics.db
